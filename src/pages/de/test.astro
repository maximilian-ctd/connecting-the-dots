---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import HeroSection from '../../components/HeroSection.astro';
import CustomerReferences from '../../components/CustomerReferences.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import ServicesNetwork from '../../components/ServicesNetwork.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import LeadForm from '../../components/LeadForm.astro';
import Footer from '../../components/Footer.astro';

const lang = 'de';
const currentPath = '/de/test';
---

<Layout
	title="Testseite · ConnectingTheDots (lokal)"
	description="Lokale Testseite für Hero-Video, Carousel und Animationen."
	lang={lang}
	currentPath={currentPath}
>
	<Header lang={lang} currentPath={currentPath} />
	<main>
		<!-- Hinweis: Nur auf Localhost sichtbar -->
		<div class="test-banner">
			<p>
				<strong>Lokale Testseite</strong>. Prüfe hier Hero-Video, Logo-Carousel und Texte. Live: <a href="/de/">Zur Startseite</a>
			</p>
			<p class="test-banner-cases">
				<strong>Case-Seiten (Review):</strong>
				<a href="/de/cases/digitale-transformation/">Digitale Transformation</a>
				<span class="test-banner-sep">·</span>
				<a href="/de/cases/markt-validierung/">Marktvalidierung</a>
				<span class="test-banner-sep">·</span>
				<a href="/de/cases/e-commerce-validierung/">E-Commerce-Validierung</a>
			</p>
		</div>
		<HeroSection lang={lang} />
		<CustomerReferences lang={lang} />
		<HowItWorks lang={lang} />
		<ServicesNetwork lang={lang} />
		<CaseStudy lang={lang} />
		<LeadForm lang={lang} />
	</main>
	<Footer lang={lang} currentPath={currentPath} />
</Layout>

<style>
	main {
		min-height: 100vh;
	}

	.test-banner {
		position: sticky;
		top: 0;
		z-index: 100;
		background: #0f172a;
		color: #e2e8f0;
		padding: 0.5rem 1rem;
		text-align: center;
		font-size: 0.875rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
	}

	.test-banner a {
		color: #7be0b7;
		text-decoration: underline;
	}

	.test-banner a:hover {
		color: #5dd4a0;
	}

	.test-banner-cases {
		margin-top: 0.5rem;
		font-size: 0.8125rem;
		line-height: 1.5;
	}

	.test-banner-sep {
		margin: 0 0.35rem;
		opacity: 0.6;
	}
</style>
