---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getTranslations } from '../../../i18n/translations';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = getTranslations(lang);

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => data.lang === 'en');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();
const currentPath = `/en/blog/${post.slug}`;
const articleUrl = new URL(currentPath, Astro.site || 'https://connectingthe.de').href;
const articleImage = post.data.heroImage
	? (post.data.heroImage.startsWith('http')
		? post.data.heroImage
		: new URL(post.data.heroImage, Astro.site || 'https://connectingthe.de').href)
	: undefined;
---

<Layout 
	title={`${post.data.title} · Blog · ConnectingTheDots`}
	description={post.data.description}
	lang={lang}
	currentPath={currentPath}
	image={post.data.heroImage}
	type="article"
>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		"headline": post.data.title,
		"description": post.data.description,
		"datePublished": post.data.pubDate.toISOString(),
		"dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
		"author": {
			"@type": "Person",
			"name": post.data.author
		},
		"publisher": {
			"@type": "Organization",
			"name": "ConnectingTheDots",
			"logo": {
				"@type": "ImageObject",
				"url": new URL('/images/Logo_CTD.png', Astro.site || 'https://connectingthe.de').href
			}
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": articleUrl
		},
		"inLanguage": "en-US",
		...(articleImage ? { "image": [articleImage] } : {})
	})} />
	<Header lang={lang} currentPath={currentPath} />
	<main class="bg-white">
		<!-- Hero Section -->
		{post.data.heroImage && (
			<section class="relative h-64 md:h-96 overflow-hidden">
				<img
					src={post.data.heroImage}
					alt={post.data.title}
					class="absolute inset-0 w-full h-full object-cover"
					loading="eager"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
			</section>
		)}
		
		<!-- Article Content -->
		<article class="max-w-4xl mx-auto px-4 py-12">
			<!-- Header -->
			<header class="mb-10 pb-8 border-b border-accent/20">
				<div class="flex flex-wrap items-center gap-3 mb-5">
					<span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm font-medium">
						{t.blog.category[post.data.category]}
					</span>
					{post.data.tags.map((tag) => (
						<span class="px-3 py-1 bg-secondary/30 text-muted-foreground rounded-full text-sm">
							{tag}
						</span>
					))}
				</div>
				<h1 class="text-4xl lg:text-5xl font-bold mb-4 text-foreground">
					{post.data.title}
				</h1>
				<div class="flex flex-wrap items-center gap-4 text-muted-foreground text-sm">
					<span>
						{t.blog.publishedOn} {post.data.pubDate.toLocaleDateString('en-US', { 
							year: 'numeric', 
							month: 'long', 
							day: 'numeric' 
						})}
					</span>
					{post.data.updatedDate && (
						<span>
							{t.blog.updatedOn} {post.data.updatedDate.toLocaleDateString('en-US', { 
								year: 'numeric', 
								month: 'long', 
								day: 'numeric' 
							})}
						</span>
					)}
					<span>•</span>
					<span>{post.data.author}</span>
				</div>
			</header>

			<!-- Content -->
			<div class="blog-content prose prose-lg max-w-none">
				<Content />
			</div>

			<!-- Back Link -->
			<div class="mt-12 pt-8 border-t border-accent/20">
				<a 
					href="/en/blog"
					class="inline-flex items-center gap-2 text-accent hover:text-accent/80 font-medium transition-colors"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
					</svg>
					{t.blog.backToBlog}
				</a>
			</div>
		</article>
	</main>
	<Footer lang={lang} currentPath={currentPath} />
</Layout>

<style>
	.blog-content {
		color: var(--color-muted-foreground);
	}

	.blog-content :global(h1:first-child) {
		display: none;
	}

	.blog-content :global(h2) {
		font-size: clamp(1.5rem, 2.2vw, 2rem);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--color-foreground);
	}

	.blog-content :global(h3) {
		font-size: clamp(1.25rem, 1.8vw, 1.5rem);
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--color-foreground);
	}

	.blog-content :global(p) {
		line-height: 1.85;
		margin-bottom: 1.1rem;
	}

	.blog-content :global(ul) {
		margin: 1rem 0 1.5rem;
		padding-left: 1.2rem;
	}

	.blog-content :global(li) {
		margin-bottom: 0.55rem;
		padding-left: 0.2rem;
	}

	.blog-content :global(strong) {
		color: var(--color-foreground);
		font-weight: 650;
	}

	/* Highlight / Callout Box */
	.blog-content :global(.callout) {
		background: linear-gradient(135deg, rgba(123, 224, 183, 0.08) 0%, rgba(123, 224, 183, 0.03) 100%);
		border-left: 4px solid var(--color-accent);
		border-radius: 0 12px 12px 0;
		padding: 1.25rem 1.5rem;
		margin: 2rem 0;
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.blog-content :global(.callout p) {
		margin-bottom: 0;
	}

	/* KPI / Result Cards */
	.blog-content :global(.kpi-grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
		margin: 2rem 0;
	}

	.blog-content :global(.kpi-card) {
		background: white;
		border: 1px solid rgba(123, 224, 183, 0.3);
		border-radius: 12px;
		padding: 1.25rem;
		text-align: center;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.blog-content :global(.kpi-card:hover) {
		box-shadow: 0 8px 24px rgba(123, 224, 183, 0.15);
		transform: translateY(-2px);
	}

	.blog-content :global(.kpi-icon) {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.blog-content :global(.kpi-label) {
		font-size: 0.85rem;
		color: var(--color-muted-foreground);
		margin-bottom: 0;
		line-height: 1.4;
	}

	.blog-content :global(.kpi-value) {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--color-foreground);
		margin-bottom: 0.25rem;
	}

	/* Auf einen Blick Summary Box */
	.blog-content :global(.summary-box) {
		background: var(--color-secondary);
		border-radius: 16px;
		padding: 1.75rem 2rem;
		margin: 2rem 0 2.5rem;
	}

	.blog-content :global(.summary-box h3) {
		margin-top: 0;
		font-size: 1.15rem;
		color: var(--color-foreground);
	}

	.blog-content :global(.summary-box ul) {
		margin-bottom: 0;
	}

	/* Testimonial Styling */
	.blog-content :global(blockquote) {
		background: linear-gradient(135deg, rgba(123, 224, 183, 0.06) 0%, rgba(123, 224, 183, 0.02) 100%);
		border-left: 4px solid var(--color-accent);
		border-radius: 0 16px 16px 0;
		padding: 2rem 2rem 1.5rem;
		margin: 2.5rem 0;
		position: relative;
	}

	.blog-content :global(blockquote::before) {
		content: '\201E';
		position: absolute;
		top: -0.25rem;
		left: 1rem;
		font-size: 4rem;
		color: var(--color-accent);
		opacity: 0.3;
		line-height: 1;
		font-family: Georgia, serif;
	}

	.blog-content :global(blockquote p) {
		font-style: italic;
		color: var(--color-foreground);
		font-size: 1.05rem;
		line-height: 1.8;
		position: relative;
		z-index: 1;
	}

	.blog-content :global(blockquote strong) {
		font-style: normal;
		color: var(--color-foreground);
	}

	/* Visual Separator */
	.blog-content :global(hr) {
		border: none;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
		margin: 2.5rem 0;
		opacity: 0.4;
	}

	/* Phase / Step indicators */
	.blog-content :global(.phase-tag) {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-accent-foreground);
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.75rem;
		border-radius: 999px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}
</style>

