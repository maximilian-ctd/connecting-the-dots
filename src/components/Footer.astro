---
// Footer-Komponente für ConnectingTheDots
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getTranslations, type Language } from '../i18n/translations';

interface Props {
  lang?: Language;
  currentPath?: string;
}

const { lang = 'de', currentPath = '/de' } = Astro.props;
const t = getTranslations(lang);
const contactHref = `/${lang}/#contact`;
---

<footer class="bg-primary text-primary-foreground py-16 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <!-- Logo & Description -->
      <div class="md:col-span-2 space-y-4">
        <div class="space-y-3">
        <div class="flex-shrink-0 ml-0 lg:ml-0">
            <img
              src="/images/Logo_CTD-footer.svg"
              alt="ConnectingTheDots"
              class="h-12 sm:h-14 lg:h-16 w-auto object-contain transition duration-300 ease-out"
              loading="lazy"
            />
          </div>
          <p class="text-primary-foreground/80 leading-relaxed max-w-md">
            {t.footer.description}
          </p>
        </div>
      </div>
      
      <!-- Links -->
      <div class="space-y-4">
        <h4 class="text-lg">{t.footer.company}</h4>
        <ul class="space-y-2 text-primary-foreground/80">
          <li><a href={`/${lang === 'de' ? 'de/unser-team' : 'en/our-team'}`} class="hover:text-accent transition-colors">{t.footer.aboutUs}</a></li>
          <li><a href={`/${lang}/blog`} class="hover:text-accent transition-colors">{t.footer.blog}</a></li>
        </ul>
      </div>
      
          <div class="space-y-4">
            <h4 class="text-lg">{t.footer.legal}</h4>
            <ul class="space-y-2 text-primary-foreground/80">
              <li><a href={`/${lang}/impressum`} class="hover:text-accent transition-colors">{t.footer.impressum}</a></li>
              <li><a href={`/${lang}/datenschutz`} class="hover:text-accent transition-colors">{t.footer.datenschutz}</a></li>
              <li><a href={contactHref} class="hover:text-accent transition-colors">{t.footer.contact}</a></li>
            </ul>
          </div>
    </div>
    
    <!-- Separator -->
    <div class="h-px bg-primary-foreground/20 mb-8"></div>
    
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4">
        <p class="text-primary-foreground/60 text-sm">
          {t.footer.copyright}
        </p>
        <span class="hidden sm:inline text-primary-foreground/30">|</span>
        <p class="text-primary-foreground/60 text-sm flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          {t.footer.bafaBadge}
        </p>
      </div>
      
      <div class="flex items-center gap-4">
        <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
        <div class="flex gap-6">
          <a href="https://www.linkedin.com/company/connectingthedots1/" target="_blank" rel="noopener noreferrer" class="text-primary-foreground/60 hover:text-accent transition-colors">
            {t.footer.linkedin}
          </a>
          <a href="mailto:maximilian@connectingthe.de" class="text-primary-foreground/60 hover:text-accent transition-colors">
            {t.footer.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

